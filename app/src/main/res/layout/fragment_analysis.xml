<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.AnalysisFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spending Summary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Category Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipBills"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bills"
                    android:textColor="#FFFFFF"
                    android:background="#C0392B"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipCoffee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coffee"
                    android:textColor="#27AE60"
                    android:background="#ABEBC6"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipSchoolSupplies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School Supplies"
                    android:textColor="#1A5276"
                    android:background="#AED6F1"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipMisc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Misc"
                    android:textColor="#6C3483"
                    android:background="#D2B4DE"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Slider -->
        <SeekBar
            android:id="@+id/seekBarMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:max="11"
            android:progress="2" />

        <!-- Status Rows -->
        <!-- Row 1: Checkmark + Red -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <CheckBox
                android:id="@+id/cbBills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatusBills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All Monthly Bills Paid"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAlignment="center"
                android:background="#C0392B"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Row 2: Checkmark + Green -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <CheckBox
                android:id="@+id/cbCoffee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatusCoffee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Coffee Expenses Within Budget"
                android:textColor="#27AE60"
                android:textAlignment="center"
                android:background="#A9DFBF"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Row 3: Checkmark + Blue -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <CheckBox
                android:id="@+id/cbSchool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatusSchool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Textbooks Purchased"
                android:textColor="#1A5276"
                android:textAlignment="center"
                android:background="#AED6F1"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Row 4: Warning + Pink -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_dialog_alert"
                android:layout_marginEnd="8dp"
                app:tint="#FFC300"/>

            <TextView
                android:id="@+id/tvStatusMisc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unnecessary Expenses Exceeded"
                android:textColor="#6C3483"
                android:textAlignment="center"
                android:background="#D2B4DE"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Budget vs Actual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Misc Purchases Budget"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvBudgetAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$30.00"
                android:textSize="16sp"
                android:background="#E8E8E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Actual Amount Spent"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvActualAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$60.00"
                android:textSize="16sp"
                android:background="#E8E8E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Chart Placeholder -->
        <FrameLayout
            android:id="@+id/chartContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="#E8E8E8">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:text="April"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="[Chart goes here]"
                android:textColor="#AAAAAA" />
        </FrameLayout>

        <!-- Let's Review Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's Review:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="You Exceeded:"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvExceededAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$30.00"
                android:textSize="15sp"
                android:background="#E8E8E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This occurred after purchase(s):"
            android:textSize="15sp"
            android:layout_marginBottom="8dp" />

        <!-- Purchase Row -->
        <LinearLayout
            android:id="@+id/llPurchaseRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewPurchaseColor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#D2B4DE"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvPurchaseName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Steam Store"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPurchaseAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$30.00"
                android:textSize="15sp"
                android:background="#E8E8E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>